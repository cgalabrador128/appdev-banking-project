<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.AreaChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="700.0" spacing="15.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.TransactionHistoryController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <Label text="Transaction History">
                    <font>
                        <Font name="System Bold" size="20.0" />
                    </font>
                </Label>
                <Pane HBox.hgrow="ALWAYS" />
                <PasswordField fx:id="pinField" promptText="Enter PIN to Unlock" />
                <Button fx:id="unlockBtn" mnemonicParsing="false" onAction="#onUnlockClick" styleClass="accent" text="Unlock" />
                <Button fx:id="exitBtn" mnemonicParsing="false" onAction="#onExitClick" text="Exit" />
            </children>
        </HBox>
        
        <Separator prefWidth="200.0" />
        
        <VBox fx:id="historyContent" disable="true" spacing="15.0" VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0">
                    <children>
                        <Label text="View Balance via:" textFill="#475569" />
                        <ComboBox fx:id="timeFilterCombo" promptText="Select timeframe..." />
                    </children>
                </HBox>
                
                <AreaChart fx:id="balanceChart" prefHeight="250.0" title="Account Balance">
                    <xAxis>
                        <CategoryAxis side="BOTTOM" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis side="LEFT" />
                    </yAxis>
                </AreaChart>
                
                <TableView fx:id="transactionsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colLog" prefWidth="600.0" text="Transaction Details" />
                    </columns>
                </TableView>
            </children>
        </VBox>
    </children>
</VBox>
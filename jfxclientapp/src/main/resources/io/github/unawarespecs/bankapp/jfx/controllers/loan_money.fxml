<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<TabPane tabClosingPolicy="UNAVAILABLE" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.unawarespecs.bankdb.controllers.LoanCustomerController">
    <tabs>
        <Tab text="View Loans Dashboard">
            <VBox spacing="15.0">
                <padding>
                    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                </padding>
                <children>
                    <TableView fx:id="loansTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colNo" prefWidth="50.0" text="No." />
                            <TableColumn fx:id="colLoanMoney" prefWidth="120.0" text="Loan Money" />
                            <TableColumn fx:id="colLeftRepay" prefWidth="120.0" text="Left to Repay" />
                            <TableColumn fx:id="colDuration" prefWidth="100.0" text="Duration" />
                            <TableColumn fx:id="colInterestRate" prefWidth="100.0" text="Interest Rate" />
                            <TableColumn fx:id="colInstallment" prefWidth="140.0" text="Installment/Month" />
                        </columns>
                    </TableView>
                    
                    <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #f8fafc; -fx-padding: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 5;">
                        <children>
                            <VBox spacing="5.0">
                                <Label text="Total Loaned Money:" textFill="#64748b" />
                                <Label fx:id="totalLoanedLabel" text="\$0.00">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Total to Repay:" textFill="#64748b" />
                                <Label fx:id="totalRepayLabel" text="\$0.00">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                            </VBox>
                            <VBox spacing="5.0">
                                <Label text="Total Installments:" textFill="#64748b" />
                                <Label fx:id="totalInstallmentsLabel" text="\$0.00/mo">
                                    <font><Font name="System Bold" size="14.0" /></font>
                                </Label>
                            </VBox>
                            
                            <Pane HBox.hgrow="ALWAYS" />
                            <Button fx:id="payLoanBtn" mnemonicParsing="false" onAction="#onPayLoanClick" prefHeight="40.0" style="-fx-background-color: #10b981; -fx-text-fill: white;" text="Pay Existing Loan" />
                        </children>
                    </HBox>
                </children>
            </VBox>
        </Tab>
        
        <Tab text="Create New Loan">
            <VBox alignment="CENTER" spacing="20.0">
                <children>
                    <Label text="Apply for a New Loan">
                        <font>
                            <Font name="System Bold" size="20.0" />
                        </font>
                    </Label>
                    <VBox alignment="CENTER_LEFT" maxWidth="300.0" spacing="5.0">
                        <Label text="Select Loan Plan" textFill="#475569" />
                        <ComboBox fx:id="loanPlanCombo" maxWidth="1.7976931348623157E308" promptText="Choose a plan..." />
                    </VBox>
                    <VBox alignment="CENTER_LEFT" maxWidth="300.0" spacing="5.0">
                        <Label text="Loan Amount ($)" textFill="#475569" />
                        <TextField fx:id="loanAmountField" promptText="0.00" />
                    </VBox>
                    <Button fx:id="applyLoanBtn" mnemonicParsing="false" onAction="#onApplyLoanClick" prefWidth="150.0" styleClass="accent" text="Apply for Loan" />
                </children>
            </VBox>
        </Tab>
        
        <Tab text="Credit Score">
            <VBox alignment="CENTER" spacing="20.0">
                <children>
                    <Label text="Your Credit Score" textFill="#64748b">
                        <font>
                            <Font size="18.0" />
                        </font>
                    </Label>
                    <Label fx:id="creditScoreLabel" text="700" textFill="#0f172a">
                        <font>
                            <Font name="System Bold" size="64.0" />
                        </font>
                    </Label>
                    <Label fx:id="creditAlertLabel" textFill="#ef4444" wrapText="true" />
                    <Button fx:id="manageCreditBtn" mnemonicParsing="false" onAction="#onManageCreditClick" text="Manage Credit Score" />
                </children>
            </VBox>
        </Tab>
    </tabs>
</TabPane>